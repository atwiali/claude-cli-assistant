{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",

    /* Output */
    "outDir": "dist",
    "rootDir": "src",

    /* Type Checking */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
